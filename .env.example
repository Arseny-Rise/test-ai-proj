# Локальная разработка
DATABASE_URL="postgresql://todo:todo_secret@localhost:5432/todo"
JWT_SECRET="change-me-to-a-long-random-string"
APP_PASSWORD="your-secure-password"

# Docker / продакшен
POSTGRES_PASSWORD="todo_secret"
DOMAIN="todo.example.com"
ACME_EMAIL="you@example.com"

# Railway (заполняется в Dashboard)
# DATABASE_URL — добавляется автоматически плагином PostgreSQL
# JWT_SECRET — задать вручную
# APP_PASSWORD — задать вручную
